{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "globals": {
    "chrome": "readonly"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "globals": {
        "describe": "readonly",
        "test": "readonly",
        "expect": "readonly"
      }
    }
  ]
}
